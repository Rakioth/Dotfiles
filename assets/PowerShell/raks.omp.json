{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": false,
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "#CE3ED6",
          "template": "@{{ .UserName }} \u279c"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#C698F2",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "agnoster_short"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#E6C229",
          "template": "(\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}) "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#C698F2",
          "template": "<#CE3ED6>git(</>{{ .HEAD }}<#CE3ED6>) </>",
          "properties": {
            "branch_icon": ""
          }
        }
      ]
    }
  ]
}